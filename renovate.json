{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>descope-sample-apps/renovate-config"],
  "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"],
  "constraints": {
    "go": "1.26"
  },
  "packageRules": [
    {
      "description": "Keep vitest and its lockstep-versioned plugins together; @vitest/* declare exact peer deps on vitest, so bumping them apart breaks lockfile resolution (ERESOLVE).",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "vitest",
        "@vitest/coverage-v8",
        "@vitest/browser",
        "@vitest/ui"
      ],
      "groupName": "vitest monorepo"
    },
    {
      "description": "Keep CodeMirror 6 packages together; they share lockstep peer ranges and are bundled into web/vendor/codemirror6.js during builds.",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "codemirror",
        "@codemirror/state",
        "@codemirror/view",
        "@codemirror/commands",
        "@codemirror/language",
        "@codemirror/lang-sql",
        "@lezer/highlight"
      ],
      "groupName": "codemirror 6"
    }
  ]
}
